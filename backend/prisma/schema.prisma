generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  SUCCESS
  EXPIRED
  CANCELLED
}

enum SeatStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
}

// --- Models ---

model Role {
  role_id   Int    @id @default(autoincrement())
  role_name String @unique // admin, staff, user
  users     User[]
}

model User {
  user_id      String    @id // ใช้ Firebase UID ที่นี่
  user_name    String
  phone_number String?   @unique // Social login บางเจ้าอาจไม่มีเบอร์โทร ให้เป็น optional
  email        String    @unique
  image_url    String?
  status       Boolean   @default(true)
  role_id      Int       @default(1) // กำหนดค่าเริ่มต้นเป็น User ปกติ
  role         Role      @relation(fields: [role_id], references: [role_id])
  bookings     Booking[]
  payments     Payment[]
}

model Concert {
  concert_id           Int       @id @default(autoincrement())
  concert_name         String
  concert_detail       String?
  image_url            String?
  location             String
  is_visible           Boolean   @default(false)
  show_times            Showtime[] 
  sale_start_time      DateTime
  max_tickets_per_user Int       @default(2)
  zones                Zone[]
  bookings             Booking[]
}

model Showtime {
  showtime_id   Int      @id @default(autoincrement())
  show_date     DateTime 
  concert_id    Int
  concert       Concert  @relation(fields: [concert_id], references: [concert_id])
  seats       Seat[]
}

model Zone {
  zone_id     Int     @id @default(autoincrement())
  zone_name   String
  price       Decimal @db.Decimal(10, 2)
  total_seats Int
  concert_id  Int
  concert     Concert @relation(fields: [concert_id], references: [concert_id],onDelete: Cascade)
  seats       Seat[]
}

model Seat {
  seat_id        Int           @id @default(autoincrement())
  zone_id        Int
  showtime_id    Int
  showtime       Showtime      @relation(fields: [showtime_id], references: [showtime_id],onDelete: Cascade)
  zone           Zone          @relation(fields: [zone_id], references: [zone_id],onDelete: Cascade)
  seat_number    String
  status         SeatStatus    @default(AVAILABLE)
  reserved_until DateTime?
  booking_items  BookingItem[]

  // ป้องกันเลขที่นั่งซ้ำกันในโซนเดียวกัน
  @@unique([zone_id, seat_number,showtime_id])
}

model Booking {
  booking_id    Int           @id @default(autoincrement())
  user_id       String
  user          User          @relation(fields: [user_id], references: [user_id])
  concert_id    Int
  concert       Concert       @relation(fields: [concert_id], references: [concert_id])
  total_price   Decimal       @db.Decimal(10, 2)
  status        BookingStatus @default(PENDING)
  created_at    DateTime      @default(now())
  booking_items BookingItem[]
  payments      Payment[]
  invoices      Invoice[]
}

model BookingItem {
  booking_item_id Int     @id @default(autoincrement())
  booking_id      Int
  booking         Booking @relation(fields: [booking_id], references: [booking_id])
  seat_id         Int
  seat            Seat    @relation(fields: [seat_id], references: [seat_id])

  // ป้องกันไม่ให้ที่นั่งตัวเดิมถูกผูกกับการจองใบเดิมซ้ำ (Data Integrity)
  @@unique([booking_id, seat_id])
}

model Payment {
  payment_id     Int           @id @default(autoincrement())
  user_id        String
  user           User          @relation(fields: [user_id], references: [user_id])
  booking_id     Int
  booking        Booking       @relation(fields: [booking_id], references: [booking_id])
  amount         Decimal       @db.Decimal(10, 2)
  payment_method String
  transaction_id String?       @unique
  paid_at        DateTime? // เปลี่ยนเป็น Optional เพราะถ้า Pending จะยังไม่มีเวลาจ่าย
  status         PaymentStatus @default(PENDING)
  receipts       Receipt[]
}

model Invoice {
  invoice_id     Int           @id @default(autoincrement())
  booking_id     Int
  booking        Booking       @relation(fields: [booking_id], references: [booking_id])
  invoice_number String        @unique
  due_date       DateTime
  status         InvoiceStatus @default(UNPAID)
  created_at     DateTime      @default(now())
}

model Receipt {
  receipt_id     Int      @id @default(autoincrement())
  payment_id     Int
  payment        Payment  @relation(fields: [payment_id], references: [payment_id])
  receipt_number String   @unique
  amount_price   Decimal  @db.Decimal(10, 2)
  issued_at      DateTime @default(now())
  pdf_url        String?
}
